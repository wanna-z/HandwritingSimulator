<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 页面设置区域 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="页面设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- 左边距和右边距一行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="左边距"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/marginLeftMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/marginLeftEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="4"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/marginLeftPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="右边距"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/marginRightMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/marginRightEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="4"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/marginRightPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 上边距和下边距一行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="上边距"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/marginTopMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/marginTopEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="4"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/marginTopPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="下边距"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/marginBottomMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/marginBottomEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="4"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/marginBottomPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/darker_gray"
            android:layout_marginVertical="16dp"/>

        <!-- 文本设置区域 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="文本设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- 文字颜色、粗体、斜体在同一行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="文字颜色"
                android:textSize="14sp"
                android:layout_marginEnd="12dp"/>

            <ImageView
                android:id="@+id/textColorView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="centerCrop"
                android:clickable="true"
                android:focusable="true"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="文字样式"
                android:textSize="14sp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/boldButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="40dp"
                android:gravity="center"
                android:text="B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/italicButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="40dp"
                android:gravity="center"
                android:text="I"
                android:textSize="18sp"
                android:textStyle="italic"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- 字体大小和大小波动一行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字体大小"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/sizeMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/sizeEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:maxLength="10"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/sizePlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="大小波动"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/sizeFluctuateMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/sizeFluctuateEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:maxLength="3"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/sizeFluctuatePlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- 字间距和字距波动一行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字间距"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/spacingMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/spacingEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:maxLength="10"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/spacingPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字距波动"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/spacingFluctuateMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/spacingFluctuateEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:maxLength="3"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/spacingFluctuatePlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- 行间距和行距波动一行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="行间距"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/lineSpacingMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/lineSpacingEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:maxLength="10"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/lineSpacingPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="行距波动"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/lineSpacingFluctuateMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/lineSpacingFluctuateEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:maxLength="3"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/lineSpacingFluctuatePlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- 画笔宽度和角度波动一行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="笔迹粗细"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/textStrokeWidthMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/textStrokeWidthEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:maxLength="10"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/textStrokeWidthPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="角度波动"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/angleFluctuateMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/angleFluctuateEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:maxLength="3"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/angleFluctuatePlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- 行首缩进 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="行前缩进"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/textIndentMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/textIndentEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:maxLength="10"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/textIndentPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

        </LinearLayout>

        <!-- 下划线区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginVertical="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="下划线"
                android:textSize="18sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <CheckBox
                android:id="@+id/underlineCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- 下划线颜色和宽度一行 -->
        <LinearLayout
            android:id="@+id/underlineParamLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="下划线颜色"
                android:textSize="14sp"
                android:layout_marginEnd="12dp"/>

            <ImageView
                android:id="@+id/underlineColorView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="centerCrop"
                android:clickable="true"
                android:focusable="true"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="下划线宽度"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/underlineMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="-"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/underlineEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:maxLength="3"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/underlinePlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:gravity="center"
                android:text="+"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>